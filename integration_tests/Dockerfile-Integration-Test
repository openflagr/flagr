# syntax=docker/dockerfile:1
FROM golang:1.26-alpine AS go_builder
WORKDIR /go/src/github.com/openflagr/flagr
RUN apk add --no-cache git make build-base

# Cache Go modules — only re-downloaded when go.mod/go.sum change.
COPY go.mod go.sum ./
RUN go mod download

# Cache Go build artifacts via BuildKit mount.
COPY . .
ENV CGO_ENABLED=0
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    make build

FROM alpine

COPY --from=go_builder /go/src/github.com/openflagr/flagr/flagr .

ENV HOST=0.0.0.0
ENV PORT=18000
ENV FLAGR_DB_DBDRIVER=sqlite3
ENV FLAGR_RECORDER_ENABLED=false
ENV FLAGR_INJECTED_CONTEXT_ENABLED=true
ENV FLAGR_INJECTED_CONTEXT_HTTP_HEADERS=X-Environment,X-Tenant-ID
ENV FLAGR_INJECTED_CONTEXT_HTTP_HEADER_PREFIXES=CF-
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
USER appuser
EXPOSE 18000

CMD "./flagr"
